##Main Menu Generator
function openCommandsMenu(p: player, lang: text):
    set metadata tag "Commands" of {_p} to chest inventory with 3 rows named "%{labels::%{_lang}%::commands::title}%"
    set slot 0 of metadata tag "Commands" of {_p} to grass block named "%{labels::%{_lang}%::commands::wild}%" with lore "%{lores::%{_lang}%::commands::wild}%"
    set slot 4 of metadata tag "Commands" of {_p} to red bed named "%{labels::%{_lang}%::commands::home}%" with lore "%{lores::%{_lang}%::commands::home}%"
    set slot 8 of metadata tag "Commands" of {_p} to lodestone named "%{labels::%{_lang}%::commands::sethome}%" with lore "%{lores::%{_lang}%::commands::sethome}%"
    set slot 9 of metadata tag "Commands" of {_p} to ender pearl named "%{labels::%{_lang}%::commands::tp}%" with lore "%{lores::%{_lang}%::commands::tp}%"
    set slot 13 of metadata tag "Commands" of {_p} to respawn anchor named "%{labels::%{_lang}%::commands::back}%" with lore "%{lores::%{_lang}%::commands::back}%"
    set slot 17 of metadata tag "Commands" of {_p} to crafting table named "%{labels::%{_lang}%::commands::location}%" with lore "%{lores::%{_lang}%::commands::location}%"
    set slot 18 of metadata tag "Commands" of {_p} to wither skeleton skull named "666" with lore "%{lores::%{_lang}%::commands::666}%"
    set slot 22 of metadata tag "Commands" of {_p} to skeleton skull named "%{labels::%{_lang}%::commands::grave}%" with lore "%{lores::%{_lang}%::commands::grave}%"
    set slot 26 of metadata tag "Commands" of {_p} to totem of undying named "%{labels::%{_lang}%::commands::pray}%" with lore "%{lores::%{_lang}%::commands::pray}%"
    open (metadata tag "Commands" of {_p}) to {_p}

##TP Menu Generator
function openTPMenu(p: player, lang: text):
    set metadata tag "TPMain" of {_p} to chest inventory with 3 rows named "%{labels::%{_lang}%::tp::title}%"
    set slot 9 of metadata tag "TPMain" of {_p} to yellow concrete named "%{labels::%{_lang}%::tp::tpa}%"
    set slot 13 of metadata tag "TPMain" of {_p} to green concrete named "%{labels::%{_lang}%::tp::tpk}%"
    set slot 17 of metadata tag "TPMain" of {_p} to red concrete named "%{labels::%{_lang}%::tp::tpc}%"
    open (metadata tag "TPMain" of {_p}) to {_p}

##Location Menu Generator
function openLocationMenu(p: player, lang: text):
    set metadata tag "LocationMain" of {_p} to chest inventory with 3 rows named "%{labels::%{_lang}%::location::title}%"
    set slot 4 of metadata tag "LocationMain" of {_p} to command block named "%{labels::%{_lang}%::location::setIcon}%"
    set slot 9 of metadata tag "LocationMain" of {_p} to grass block named "%{labels::%{_lang}%::location::add}%"
    set slot 13 of metadata tag "LocationMain" of {_p} to paper named "%{labels::%{_lang}%::location::save}%" with lore "%{lores::%{_lang}%::location::save}%"
    set slot 17 of metadata tag "LocationMain" of {_p} to crafting table named "%{labels::%{_lang}%::location::goto}%"
    set slot 18 of metadata tag "LocationMain" of {_p} to barrier named "%{labels::%{_lang}%::location::remove}%" with lore "%{lores::%{_lang}%::location::remove}%"
    set slot 22 of metadata tag "LocationMain" of {_p} to writable_book named "%{labels::%{_lang}%::location::unsave}%" with lore "%{lores::%{_lang}%::location::unsave}%"
    set slot 26 of metadata tag "LocationMain" of {_p} to book named "%{labels::%{_lang}%::location::saved}%" with lore "%{lores::%{_lang}%::location::saved}%"
    open (metadata tag "LocationMain" of {_p}) to {_p}


##TP Request Menu Generator
function openTPAskMenu(p: player, lang: text):
    set metadata tag "TPAsk" of {_p} to chest inventory with 3 rows named "%{labels::%{_lang}%::tp::chest}%"
    set {_count} to 0
    loop all players:
        set slot {_count} of metadata tag "TPAsk" of {_p} to loop-player's skull named "%loop-player%"
        set {_count} to {_count} + 1
    open (metadata tag "TPAsk" of {_p}) to {_p}

##TP Accept Menu Generator
function openTPCancelMenu(p: player, lang: text):
    set metadata tag "TPCancel" of {_p} to chest inventory with 3 rows named "%{labels::%{_lang}%::tp::chest}%"
    set {_count} to 0
    loop all players:
        set slot {_count} of metadata tag "TPCancel" of {_p} to loop-player's skull named "%loop-player%"
        set {_count} to {_count} + 1
    open (metadata tag "TPCancel" of {_p}) to {_p}

function openLocationAnvil(p: player, status: text, lang: text):
    set {status::%uuid of {_p}%} to {_status}
    # skBee: open a real functional anvil to the player
    open real anvil named "%{labels::%{_lang}%::location::anvil::title}%" to {_p}
    # Wait 1 tick so the inventory is fully open before setting the input item
    wait 1 tick
    set slot 0 of {_p}'s current inventory to paper named "%{labels::%{_lang}%::location::anvil::text}%"

##Paginated Location Menu Generator
function openPaginatedLocations(p: player, lang: text):
    set {selectedPage::%uuid of {_p}%} to 0
    clear {locationPages::%uuid of {_p}%::*}
    set {_page} to 0
    set {_count} to 0
    add "Locations%{_page}%" to {locationPages::%uuid of {_p}%::*}
    loop {sortedLocations::*}:
        if {_count} > 24:
            set {_count} to 0
            set {_page} to {_page} + 1
            add "Locations%{_page}%" to {locationPages::%uuid of {_p}%::*}
        add "%loop-value%" to {locationPages::%uuid of {_p}%::Locations%{_page}%::*}
        set {_count} to {_count} + 1
    loop {locationPages::%uuid of {_p}%::*}:
        set metadata tag "%loop-value%" of {_p} to chest inventory with 3 rows named "%loop-value%"
        set {_count} to 0
        loop {locationPages::%uuid of {_p}%::%loop-value-1%::*}:
            if {_count} is 18:
                set {_count} to {_count} + 1
            set {_lore} to "%{lores::%{_lang}%::location::popularity}%: %{location::%loop-value-2%::freq}%"
            set slot {_count} of metadata tag "%loop-value-1%" of {_p} to {location::%loop-value-2%::icon} named "%loop-value-2%" with lore "%{_lore}%"
            set {_count} to {_count} + 1
        set slot 18 of metadata tag "%loop-value%" of {_p} to redstone block named "%{labels::%{_lang}%::goto::previous}%"
        set slot 26 of metadata tag "%loop-value%" of {_p} to gold block named "%{labels::%{_lang}%::goto::next}%"
    openCurrentLocationPage({_p})

function openCurrentLocationPage(p: player):
    open (metadata tag "Locations%{selectedPage::%uuid of {_p}%}%" of {_p}) to {_p}

##Operate Saved Locations
function openSavedLocationsMenu(p: player, lang: text):
    set {_uuid} to uuid of {_p}
    set metadata tag "SavedLocations" of {_p} to chest inventory with 3 rows named "%{labels::%{_lang}%::location::saved}%"
    set {_count} to 0
    loop {savedLocations::%{_uuid}%::*}:
        if {location::%loop-value%::coords} is set:
            set {_lore} to "%{lores::%{_lang}%::location::popularity}%: %{location::%loop-value%::freq}%"
            set slot {_count} of metadata tag "SavedLocations" of {_p} to {location::%loop-value%::icon} named "%loop-value%" with lore "%{_lore}%"
            set {_count} to {_count} + 1
    open (metadata tag "SavedLocations" of {_p}) to {_p}

##Save Location
function saveLocation(p: player, target: text):
    set {_uuid} to uuid of {_p}
    set {_lang} to {language::%{_uuid}%}
    if {location::%{_target}%::coords} is set:
        if {savedLocations::%{_uuid}%::*} does not contain {_target}:
            if size of {savedLocations::%{_uuid}%::*} >= 27:
                send "%{messages::%{_lang}%::location::add::full}%" to {_p}
            else:
                add {_target} to {savedLocations::%{_uuid}%::*}
                send "%{messages::%{_lang}%::location::save::executed::1}%%{_target}%%{messages::%{_lang}%::location::save::executed::2}%" to {_p}
        else:
            send "%{messages::%{_lang}%::location::add::fail}%" to {_p}
    else:
        send "%{messages::%{_lang}%::goto::fail}%" to {_p}

##Unsave Location
function unsaveLocation(p: player, target: text):
    set {_uuid} to uuid of {_p}
    set {_lang} to {language::%{_uuid}%}
    if {savedLocations::%{_uuid}%::*} contains {_target}:
        remove {_target} from {savedLocations::%{_uuid}%::*}
        send "%{messages::%{_lang}%::location::unsave::executed::1}%%{_target}%%{messages::%{_lang}%::location::unsave::executed::2}%" to {_p}
    else:
        send "%{messages::%{_lang}%::location::remove::fail}%" to {_p}

## GUI Click Handlers
function handleCommandsMenuClick(p: player, slotObj: integer):
    if {_slotObj} is 0:
        close {_p}'s inventory
        toWilderness({_p})
    else if {_slotObj} is 4:
        close {_p}'s inventory
        goHome({_p})
    else if {_slotObj} is 8:
        close {_p}'s inventory
        setHome({_p})
    else if {_slotObj} is 9:
        close {_p}'s inventory
        openTPMenu({_p}, {language::%uuid of {_p}%})
    else if {_slotObj} is 13:
        close {_p}'s inventory
        goBack({_p})
    else if {_slotObj} is 17:
        close {_p}'s inventory
        openLocationMenu({_p}, {language::%uuid of {_p}%})
    else if {_slotObj} is 18:
        close {_p}'s inventory
        curse({_p})
    else if {_slotObj} is 22:
        close {_p}'s inventory
        gotoGrave({_p})
    else if {_slotObj} is 26:
        close {_p}'s inventory
        bless({_p})

##Operate TP Menu
function handleTPMainMenuClick(p: player, slotObj: integer):
    if {_slotObj} is 9:
        close {_p}'s inventory
        openTPAskMenu({_p}, {language::%uuid of {_p}%})
    else if {_slotObj} is 13:
        close {_p}'s inventory
        acceptTP({_p})
    else if {_slotObj} is 17:
        close {_p}'s inventory
        openTPCancelMenu({_p}, {language::%uuid of {_p}%})

##Operate Location Menu
function handleLocationMainMenuClick(p: player, slotObj: integer):
    if {_slotObj} is 4:
        close {_p}'s inventory
        openLocationAnvil({_p}, "setLocIcon", {language::%uuid of {_p}%})
    else if {_slotObj} is 9:
        close {_p}'s inventory
        openLocationAnvil({_p}, "nameLoc", {language::%uuid of {_p}%})
    else if {_slotObj} is 13:
        close {_p}'s inventory
        openLocationAnvil({_p}, "saveLoc", {language::%uuid of {_p}%})
    else if {_slotObj} is 17:
        close {_p}'s inventory
        set {selectedPage::%uuid of {_p}%} to 0
        openPaginatedLocations({_p}, {language::%uuid of {_p}%})
    else if {_slotObj} is 18:
        close {_p}'s inventory
        openLocationAnvil({_p}, "removeLoc", {language::%uuid of {_p}%})
    else if {_slotObj} is 22:
        close {_p}'s inventory
        openLocationAnvil({_p}, "unsaveLoc", {language::%uuid of {_p}%})
    else if {_slotObj} is 26:
        close {_p}'s inventory
        openSavedLocationsMenu({_p}, {language::%uuid of {_p}%})

##Handle Anvil Input For Location Menu
function handleLocationAnvilClick(p: player, input: text):
    set {_status} to {status::%uuid of {_p}%}
    if {_status} is equal to "nameLoc":
        addLocation({_p}, {_input})
    else if {_status} is equal to "removeLoc":
        removeLocation({_p}, {_input})
    else if {_status} is equal to "setLocIcon":
        setIcon({_p}, {_input})
    else if {_status} is equal to "saveLoc":
        saveLocation({_p}, {_input})
    else if {_status} is equal to "unsaveLoc":
        unsaveLocation({_p}, {_input})
    clear {status::%uuid of {_p}%}
    # Clear anvil slots before closing so items don't drop back to the player
    set slot 0 of {_p}'s current inventory to air
    set slot 1 of {_p}'s current inventory to air
    set slot 2 of {_p}'s current inventory to air
    close {_p}'s inventory

##Handle TP Ask Click
function handleTPAskClick(p: player, i: item):
    if {_i} is set:
        if {_i} isn't air:
            set {_targetName} to uncolored name of {_i}
            set {_target} to {_targetName} parsed as player
            if {_target} is set:
                close {_p}'s inventory
                askTP({_p}, {_target})

##Handle TP Cancel Click
function handleTPCancelClick(p: player, i: item):
    if {_i} is set:
        if {_i} isn't air:
            set {_targetName} to uncolored name of {_i}
            set {_target} to {_targetName} parsed as player
            if {_target} is set:
                close {_p}'s inventory
                cancelTP({_p}, {_target})

##Handle Location Click In Paginated Menu
function handleSavedLocationsClick(p: player, i: item):
    if {_i} is set:
        if {_i} isn't air:
            set {_targetName} to uncolored name of {_i}
            if {location::%{_targetName}%::coords} is set:
                close {_p}'s inventory
                gotoLocation({_p}, {_targetName})

##Handle Location Click In Paginated Menu
function handleLocationPagesClick(p: player, slotObj: integer, i: item):
    if {_i} is set:
        if {_i} isn't air:
            set {_targetName} to uncolored name of {_i}
            if {location::%{_targetName}%::coords} is set:
                close {_p}'s inventory
                gotoLocation({_p}, {_targetName})
    if {_slotObj} is 26:
        set {selectedPage::%uuid of {_p}%} to {selectedPage::%uuid of {_p}%} + 1
        if size of {sortedLocations::*} > {selectedPage::%uuid of {_p}%} * 25:
            close {_p}'s inventory
            openCurrentLocationPage({_p})
        else:
            set {selectedPage::%uuid of {_p}%} to {selectedPage::%uuid of {_p}%} - 1
    else if {_slotObj} is 18:
        if {selectedPage::%uuid of {_p}%} > 0:
            close {_p}'s inventory
            set {selectedPage::%uuid of {_p}%} to {selectedPage::%uuid of {_p}%} - 1
            openCurrentLocationPage({_p})
