    else if {_slotObj} is 11:
        close {_p}'s inventory
        contractEntryPoint({_p}, "claim", null, null)
    else if {_slotObj} is 15:
        close {_p}'s inventory
        contractEntryPoint({_p}, "complete", null, null)
    else if {_slotObj} is 20:
        close {_p}'s inventory
        contractEntryPoint({_p}, "approve", null, null)
    else if {_slotObj} is 24:
        close {_p}'s inventory
        contractEntryPoint({_p}, "dispute", null, null)

