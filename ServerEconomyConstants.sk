    set {messages::default::economy::trade::item_swapped_seller} to "&6[Trade] &eSwapped your &f{1} &efor &f{2}"
    set {messages::default::economy::trade::seller_offline_swap} to "&4Seller is offline! Cannot complete item swap."

    ##Market
    set {messages::default::economy::market::usage} to "&6[Market Commands] &e/market <browse|sell|cancel|buy> [price|id]"
    set {messages::default::economy::market::sell_usage} to "&4Usage: /market sell <price>"
