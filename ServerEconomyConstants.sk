    set {messages::default::economy::transfer::amount_positive} to "&4Amount must be positive!"
    set {messages::default::economy::transfer::insufficient_balance} to "&4Insufficient balance!"
    set {messages::default::economy::transfer::sent} to "&eSent &f{1} ServerCoin &eto &f{2} &7(fee: {3})"
    set {messages::default::economy::transfer::received} to "&eReceived &f{1} ServerCoin &efrom &f{2}"

    ##Swap
    set {messages::default::economy::swap::not_enough_emeralds} to "&4Not enough emeralds!"
    set {messages::default::economy::swap::trade_too_small} to "&4Trade too small or too large!"
    set {messages::default::economy::swap::swapped_em_to_coin} to "&eSwapped &f{1} emeralds &efor &f{2} ServerCoin"
    set {messages::default::economy::swap::swapped_coin_to_em} to "&eSwapped &f{1} ServerCoin &efor &f{2} emeralds"
    set {messages::default::economy::swap::price} to "&7Price: {1} coin/em"
    set {messages::default::economy::swap::trade_invalid} to "&4Trade invalid or too large!"
    set {messages::default::economy::swap::insufficient_balance} to "&4Insufficient balance!"

    ##Quest
    set {messages::default::economy::quest::new} to "&6[ServerContract] &eNew Quest: &f{1}"
    set {messages::default::economy::quest::max_supply} to "&c[ServerContract] Max supply reached. No reward."
    set {messages::default::economy::quest::complete} to "&6[ServerContract] &aComplete! &eAwarded &f{1} SC"

    ##Contracts
    set {messages::default::economy::contract::usage} to "&6[Contracts] /contract <list|create|claim|complete|approve|dispute> [args]"
    set {messages::default::economy::contract::header} to "&6===== Open Contracts ====="
    set {messages::default::economy::contract::row} to "&e#{1}: &f{2} &7- '{3}' &a({4} SC)"
    set {messages::default::economy::contract::no_open} to "&7No open contracts."
    set {messages::default::economy::contract::create_usage} to "&4Usage: /contract create <reward> <description>"
    set {messages::default::economy::contract::reward_positive} to "&4Reward must be positive!"
    set {messages::default::economy::contract::need_cost} to "&4You need {1} SC (Reward + {2} SC Validator Fee)"
    set {messages::default::economy::contract::created} to "&6[Contract] &aCreated #{1}! &eEscrowed {2} SC."
    set {messages::default::economy::contract::claim_own} to "&4You cannot claim your own contract."
    set {messages::default::economy::contract::claimed} to "&6[Contract] &aYou claimed #{1}! Type /contract complete {1} when done."
    set {messages::default::economy::contract::creator_claimed} to "&6[Contract] &eYour contract &f#{1} &ehas been claimed by &f{2}&e!"
    set {messages::default::economy::contract::submitted} to "&6[Contract] &eYou submitted #{1}. Waiting for creator approval."
    set {messages::default::economy::contract::worker_finished} to "&6[Contract] &aWorker finished #{1}! &eType &f/contract approve {1} &eor &f/contract dispute {1}"
    set {messages::default::economy::contract::approved} to "&6[Contract] &aApproved! &eRefunded {1} SC validator fee."
    set {messages::default::economy::contract::worker_paid} to "&6[Contract] &aYour work on #{1} was approved! &eReceived {2} SC."
    set {messages::default::economy::contract::disputed} to "&6[Contract] &cDisputed! &eMoved to the Public Jury Board."
    set {messages::default::economy::contract::dispute_broadcast} to "&6[Jury] &cA new dispute on contract #{1} needs a Validator! (/jury claim {1})"

    ##Jury
    set {messages::default::economy::jury::usage} to "&6[Jury] /jury <list|claim|vote> [args]"
