    set {messages::default::economy::info::swap_fee} to "&eSwap Fee: &f{1}"
    set {messages::default::economy::supply::line} to "&6[Supply] &eTotal: {1} | Minable: {2} | Generated: {3} | Remaining Pool: {4}"
##Caliberate Economy GUI Labels and Lores
function caliberateEconomyGUILabels():
    ##Main Economy Menu
    set {labels::default::economy::title} to "Economy"
    set {labels::default::economy::transfer::name} to "&6Transfer Coins"
    set {lores::default::economy::transfer} to "&7Send coins to another player||&eClick to begin transfer"
    set {labels::default::economy::swap::name} to "&aSwap Emerald ↔ Coin"
    set {lores::default::economy::swap} to "&7Trade emeralds for coins or vice versa||&eClick to swap"
    set {labels::default::economy::contracts::name} to "&dContracts"
    set {lores::default::economy::contracts} to "&7Manage contracts||&eClick to view contracts"
    set {labels::default::economy::jury::name} to "&cJury"
    set {lores::default::economy::jury} to "&7Handle disputes||&eClick to manage jury"
    set {labels::default::economy::market::name} to "&eMarket"
    set {lores::default::economy::market} to "&7Global marketplace||&eClick to access market"
    set {labels::default::economy::ptrade::name} to "&bP2P Trading"
    set {lores::default::economy::ptrade} to "&7Direct player-to-player trades||&eClick to trade"
    set {labels::default::economy::balance::name} to "&fWallet"
    set {lores::default::economy::balance} to "&7Check your balance||&eClick to view"
    set {labels::default::economy::info::name} to "&6Economy Info"
    set {lores::default::economy::info} to "&7System statistics||&eClick to view"
    set {labels::default::economy::supply::name} to "&7Supply Info"
    set {lores::default::economy::supply} to "&7Coin supply details||&eClick to view"

    ##Contract Sub-Menu
    set {labels::default::economy::contracts::submenu::title} to "Contracts"
    set {labels::default::economy::contracts::submenu::list::name} to "&6List Contracts"
    set {lores::default::economy::contracts::submenu::list} to "&7View all contracts||&eClick to list"
    set {labels::default::economy::contracts::submenu::create::name} to "&aCreate Contract"
    set {lores::default::economy::contracts::submenu::create} to "&7Create a new contract||&eClick to create"
    set {labels::default::economy::contracts::submenu::claim::name} to "&eClaim Contract"
    set {lores::default::economy::contracts::submenu::claim} to "&7Claim a contract||&eClick to claim"
    set {labels::default::economy::contracts::submenu::complete::name} to "&bComplete Contract"
    set {lores::default::economy::contracts::submenu::complete} to "&7Mark contract as done||&eClick to complete"
    set {labels::default::economy::contracts::submenu::approve::name} to "&2Approve Contract"
    set {lores::default::economy::contracts::submenu::approve} to "&7Approve completion||&eClick to approve"
    set {labels::default::economy::contracts::submenu::dispute::name} to "&cDispute Contract"
    set {lores::default::economy::contracts::submenu::dispute} to "&7Report a dispute||&eClick to dispute"

    ##Jury Sub-Menu
    set {labels::default::economy::jury::submenu::title} to "Jury"
    set {labels::default::economy::jury::submenu::list::name} to "&6List Disputes"
    set {lores::default::economy::jury::submenu::list} to "&7View pending disputes||&eClick to list"
    set {labels::default::economy::jury::submenu::vote::name} to "&cVote on Dispute"
    set {lores::default::economy::jury::submenu::vote} to "&7Cast your vote||&eClick to vote"

    ##Market Sub-Menu
    set {labels::default::economy::market::submenu::title} to "Market"
    set {labels::default::economy::market::submenu::sell::name} to "&eSell Item"
    set {lores::default::economy::market::submenu::sell} to "&7List item for sale||&eClick to sell"
    set {labels::default::economy::market::submenu::cancel::name} to "&cCancel Listing"
    set {lores::default::economy::market::submenu::cancel} to "&7Remove from market||&eClick to cancel"
    set {labels::default::economy::market::submenu::buy::name} to "&aBuy Item"
    set {lores::default::economy::market::submenu::buy} to "&7Purchase an item||&eClick to buy"
    set {labels::default::economy::market::submenu::browse::name} to "&6Browse Market"
    set {lores::default::economy::market::submenu::browse} to "&7See available items||&eClick to browse"

    ##P2P Trade Sub-Menu
    set {labels::default::economy::ptrade::submenu::title} to "P2P Trading"
    set {labels::default::economy::ptrade::submenu::offer::name} to "&6Make Offer"
    set {lores::default::economy::ptrade::submenu::offer} to "&7Offer coins for items||&eClick to offer"
    set {labels::default::economy::ptrade::submenu::itemswap::name} to "&aItem Swap"
    set {lores::default::economy::ptrade::submenu::itemswap} to "&7Exchange items||&eClick to swap"
    set {labels::default::economy::ptrade::submenu::accept::name} to "&2Accept Trade"
    set {lores::default::economy::ptrade::submenu::accept} to "&7Accept pending trade||&eClick to accept"
    set {labels::default::economy::ptrade::submenu::deny::name} to "&cDeny Trade"
    set {lores::default::economy::ptrade::submenu::deny} to "&7Reject pending trade||&eClick to deny"