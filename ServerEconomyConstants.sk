    set {messages::default::economy::market::not_owner} to "&4You do not own this listing!"
    set {messages::default::economy::market::not_found} to "&4Listing not found."
    set {messages::default::economy::market::buy_usage} to "&4Usage: /market buy <id>"
    set {messages::default::economy::market::buy_own} to "&4You cannot buy your own item! Use /market cancel {1}"
    set {messages::default::economy::market::header} to "&6===== Global Market ====="
    set {messages::default::economy::market::empty} to "&7No items currently listed."
    set {messages::default::economy::market::row} to "&e#{1} &f{2} &eby &f{3} &e- &a{4} SC"
    set {messages::default::economy::market::footer} to "&7Use &f/market buy <id> &7to purchase."

    ##P2P Trade
    set {messages::default::economy::ptrade::usage} to "&6[Trade] &e/ptrade <offer|itemswap|accept|deny> [player] [price]"
    set {messages::default::economy::ptrade::offer_usage} to "&4Usage: /ptrade offer <player> <price>"
