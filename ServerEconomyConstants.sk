    set {messages::default::economy::jury::buyer_win} to "&6[Jury] &cYou ruled in favor of the Buyer! The {1} SC was seized and recycled."
    set {messages::default::economy::jury::vote_usage} to "&4Usage: /jury vote <id> <worker|buyer>"
    set {messages::default::economy::jury::validator_paid} to "&6[Jury] &eYou received your {1} SC Validator Fee."

    ##Trade
