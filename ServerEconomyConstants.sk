##--------------------------------##
##   Server Economy Constants     ##
## This File Contains All The Constant/Default Variables For The Economy
##--------------------------------##

##--------------------------------##
##     Caliberation Functions     ##
##--------------------------------##

##Caliberate Economy Defaults
##Sets static economy configuration. Runtime state ({eco::totalMined}, {eco::contractCount})
##is preserved if already set so calibration won't wipe progress.
function caliberateEconomy():
    set {eco::maxSupply} to 1000000
    set {eco::poolGenesis} to 500000
    set {eco::baseReward} to 10
    set {eco::halvingInterval} to 200000
    set {eco::transferFee} to 2
    set {eco::swapFee} to 0.3
    set {eco::validatorFee} to 2
    if {eco::totalMined} is not set:
        set {eco::totalMined} to 0
    if {eco::contractCount} is not set:
        set {eco::contractCount} to 0
    set {eco::initialized} to true

##Caliberate AMM Pool Genesis Seed
##Only seeds the pool the first time. After genesis the reserves are owned by the market.
function caliberateAMMPool():
    if {pool::initialized} is not set:
        set {pool::coin} to {eco::poolGenesis}
        set {pool::emerald} to 10000
        set {pool::initialized} to true

##Caliberate Quest Templates
##Each template index defines: action, target, goal, multiplier, desc
function caliberateQuests():
    set {questTemplate::1::action} to "mine"
    set {questTemplate::1::target} to "stone"
    set {questTemplate::1::goal} to 128
    set {questTemplate::1::multiplier} to 1.5
    set {questTemplate::1::desc} to "Mine 128 Stone"

    set {questTemplate::2::action} to "consume"
    set {questTemplate::2::target} to "bread"
    set {questTemplate::2::goal} to 32
    set {questTemplate::2::multiplier} to 2.0
    set {questTemplate::2::desc} to "Eat 32 Bread"

    set {questTemplate::3::action} to "kill"
    set {questTemplate::3::target} to "zombie"
    set {questTemplate::3::goal} to 15
    set {questTemplate::3::multiplier} to 3.0
    set {questTemplate::3::desc} to "Slay 15 Zombies"

    set {questTemplate::4::action} to "craft"
    set {questTemplate::4::target} to "torch"
    set {questTemplate::4::goal} to 64
    set {questTemplate::4::multiplier} to 1.0
    set {questTemplate::4::desc} to "Craft 64 Torches"

    set {questTemplate::5::action} to "fish"
    set {questTemplate::5::target} to "any"
    set {questTemplate::5::goal} to 5
    set {questTemplate::5::multiplier} to 4.0
    set {questTemplate::5::desc} to "Catch 5 Fish"

    set {questTemplate::6::action} to "mine"
    set {questTemplate::6::target} to "log"
    set {questTemplate::6::goal} to 64
    set {questTemplate::6::multiplier} to 2.0
    set {questTemplate::6::desc} to "Chop 64 Logs"

    set {questTemplate::count} to 6

##Economy Messages
##Use language tags like {messages::default::economy::...}
function caliberateEconomyMessages():
